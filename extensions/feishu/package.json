{
  "name": "@crabfork/feishu",
  "version": "2026.4.12",
  "description": "Crabfork Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sinclair/typebox": "0.34.49",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@crabfork/plugin-sdk": "workspace:*",
    "crabfork": "workspace:*"
  },
  "peerDependencies": {
    "crabfork": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "crabfork": {
      "optional": true
    }
  },
  "crabfork": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@crabfork/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "build": {
      "crabforkVersion": "2026.4.12"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
