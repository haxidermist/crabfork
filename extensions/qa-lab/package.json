{
  "name": "@crabfork/qa-lab",
  "version": "2026.4.12",
  "private": true,
  "description": "Crabfork QA lab plugin with private debugger UI and scenario runner",
  "type": "module",
  "dependencies": {
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "@crabfork/plugin-sdk": "workspace:*",
    "crabfork": "workspace:*"
  },
  "peerDependencies": {
    "crabfork": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "crabfork": {
      "optional": true
    }
  },
  "crabfork": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@crabfork/qa-lab",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    }
  }
}
