{
  "name": "@crabfork/nextcloud-talk",
  "version": "2026.4.12",
  "description": "Crabfork Nextcloud Talk channel plugin",
  "type": "module",
  "devDependencies": {
    "@crabfork/plugin-sdk": "workspace:*",
    "crabfork": "workspace:*"
  },
  "peerDependencies": {
    "crabfork": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "crabfork": {
      "optional": true
    }
  },
  "crabfork": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nextcloud-talk",
      "label": "Nextcloud Talk",
      "selectionLabel": "Nextcloud Talk (self-hosted)",
      "docsPath": "/channels/nextcloud-talk",
      "docsLabel": "nextcloud-talk",
      "blurb": "Self-hosted chat via Nextcloud Talk webhook bots.",
      "aliases": [
        "nc-talk",
        "nc"
      ],
      "order": 65,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@crabfork/nextcloud-talk",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "build": {
      "crabforkVersion": "2026.4.12"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
