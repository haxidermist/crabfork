{
  "name": "@crabfork/voice-call",
  "version": "2026.4.12",
  "description": "Crabfork voice-call plugin",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "commander": "^14.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@crabfork/plugin-sdk": "workspace:*",
    "crabfork": "workspace:*"
  },
  "peerDependencies": {
    "crabfork": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "crabfork": {
      "optional": true
    }
  },
  "crabfork": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "build": {
      "crabforkVersion": "2026.4.12"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
