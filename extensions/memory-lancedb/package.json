{
  "name": "@crabfork/memory-lancedb",
  "version": "2026.4.12",
  "description": "Crabfork LanceDB-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@sinclair/typebox": "0.34.49",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@crabfork/plugin-sdk": "workspace:*"
  },
  "crabfork": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@crabfork/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "build": {
      "crabforkVersion": "2026.4.12"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
